# Required
ESP_HOME_ADDRESS=192.168.1.100:6053
LOG_LEVEL=info

# AI Configuration (Ollama)
AI_HOST=localhost
AI_PORT=11434
AI_MODEL=llama3.2
AI_SYSTEM_MESSAGE=You are a helpful home assistant.

# Wyoming Configuration (faster-whisper)
WYOMING_HOST=localhost
WYOMING_PORT=10300
WYOMING_LANGUAGE=en

# Piper TTS Configuration
PIPER_HOST=localhost
PIPER_PORT=10200
PIPER_LANGUAGE=en

# HTTP Server Configuration (for serving TTS audio)
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# VAD (Voice Activity Detection) Configuration
VAD_THRESHOLD_RATIO=2.5
VAD_MIN_SILENCE_MS=1000
