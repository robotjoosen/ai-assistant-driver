# Required
ESP_HOME_ADDRESS=192.168.1.100:6053
LOG_LEVEL=info

# AI Configuration (Ollama)
AI_HOST=localhost
AI_PORT=11434
AI_MODEL=llama3.2
AI_SYSTEM_MESSAGE=You are a helpful home assistant.

# STT (Speech-to-Text) Configuration (faster-whisper)
STT_HOST=localhost
STT_PORT=10300
STT_LANGUAGE=en

# TTS (Text-to-Speech) Configuration (Piper)
TTS_HOST=localhost
TTS_PORT=10200
TTS_LANGUAGE=en
TTS_STORAGE_PATH=./data/tts

# TTS HTTP Server Configuration (for serving TTS audio)
TTS_HTTP_HOST=0.0.0.0
TTS_HTTP_PORT=8080

# VAD (Voice Activity Detection) Configuration
VAD_THRESHOLD_RATIO=2.5
VAD_MIN_SILENCE_MS=1000
